APP_ENV=docker

DB_DRIVER=pgx
DB_HOST=localhost
# DB_HOST=localhost
DB_HOST_MIGRATE=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=example_sqlx_payment_gateway

DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m

REDIS_HOST_CLIENT=redis_client
REDIS_PORT_CLIENT=6379
REDIS_PASSWORD_CLIENT=dragon_knight
REDIS_DB_CLIENT=0

REDIS_HOST_SERVER=redis_server
REDIS_PORT_SERVER=6379
REDIS_PASSWORD_SERVER=dragon_knight
REDIS_DB_SERVER=0

DB_SEEDER=true

SECRET_KEY=yantopedia

DB_URL=postgres://DRAGON:DRAGON@postgres:5432/PAYMENT_GATEWAY
